# ─── App URL ───
# Local: http://localhost:3000
# Production: https://grindctrl.cloud
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Landing Playground Mode ───
# Server-only. Default: mock. Set to "live" to call the n8n trial inflow bridge.
LANDING_SANDBOX_MODE="mock"
LANDING_TRIAL_INFLOW_URL="https://YOUR_N8N_DOMAIN/webhook/grindctrl-trial-inflow"
LANDING_TRIAL_INFLOW_TOKEN="replace-with-server-only-token"
LANDING_TRIAL_INFLOW_TIMEOUT_MS="12000"

# ─── Clerk Authentication ───
# Development: use pk_test_ / sk_test_ keys from Clerk dashboard
# Production:  use pk_live_ / sk_live_ keys (NEVER commit live keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxx"
CLERK_SECRET_KEY="sk_test_xxxxx"

# ─── Supabase (production project: egvdxshlbcqndrcnzcdn) ───
# Same project for both dev and prod — RLS handles access control
NEXT_PUBLIC_SUPABASE_URL="https://egvdxshlbcqndrcnzcdn.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# GrindCTRL Try-On campaign email (server-only)
TRYON_EMAIL_SMTP_HOST="smtp.gmail.com"
TRYON_EMAIL_SMTP_PORT="587"
TRYON_EMAIL_SMTP_USER="grindctrlnow@gmail.com"
TRYON_EMAIL_SMTP_APP_PASSWORD="replace-with-google-app-password"
TRYON_EMAIL_FROM_NAME="GrindCTRL Try-On"
TRYON_EMAIL_REPLY_TO="grindctrlnow@gmail.com"
TRYON_EMAIL_LIVE_DEMO_URL="https://grindctrl.cloud/try-on"
TRYON_EMAIL_SEND_TOKEN="replace-with-a-long-random-server-token"
# Keep false until STOP suppression, idempotency, and an approved campaign lead resolver are connected.
TRYON_EMAIL_LIVE_SEND_ENABLED="false"
