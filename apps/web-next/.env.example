# ─── App URL ───
# Local: http://localhost:3000
# Production: https://grindctrl.cloud
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Clerk Authentication ───
# Development: use pk_test_ / sk_test_ keys from Clerk dashboard
# Production:  use pk_live_ / sk_live_ keys (NEVER commit live keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxxxx"
CLERK_SECRET_KEY="sk_test_xxxxx"

# ─── Supabase (production project: egvdxshlbcqndrcnzcdn) ───
# Same project for both dev and prod — RLS handles access control
NEXT_PUBLIC_SUPABASE_URL="https://egvdxshlbcqndrcnzcdn.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# ─── Landing Sandbox Provider (server-only) ───
# Optional. If unset, landing sandbox backend returns deterministic fallback outputs.
GROQ_API_KEY="gsk_xxxxx"
GROQ_LANDING_SANDBOX_MODEL="openai/gpt-oss-20b"
GROQ_LANDING_SANDBOX_TRANSCRIBE_MODEL="whisper-large-v3"
GROQ_LANDING_SANDBOX_TIMEOUT_MS="9000"
