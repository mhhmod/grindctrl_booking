  "scripts": {
    "postinstall": "node -e \"const fs=require('fs'),s='node_modules/@shoelace-style/shoelace/dist/assets',d='src/public/shoelace';fs.rmSync(d,{recursive:true,force:true});fs.cpSync(s,d,{recursive:true})\"",
